# FinPulse Environment Variables Template
# Copy this file to .env.local and fill in your actual API keys

# ==========================================
# WHALE DATA INTEGRATION
# ==========================================
# Whale Alert API - https://whale-alert.io/
# Free tier: 30 calls/min | Pro: $49/mo for 1000 calls/min
WHALE_ALERT_API_KEY=your_whale_alert_key_here

# ==========================================
# SOCIAL SENTIMENT INTEGRATION
# ==========================================
# X/Twitter API v2 - https://developer.twitter.com/
# Essential plan: $100/mo required for production
# Free tier: 1500 tweets/month (testing only)
TWITTER_BEARER_TOKEN=your_twitter_bearer_token_here

# OpenAI API - https://platform.openai.com/
# Used for sentiment analysis (GPT-4 Mini)
# Cost: ~$0.0001 per tweet
OPENAI_API_KEY=your_openai_key_here

# ==========================================
# TECHNICAL ANALYSIS / MARKET DATA
# ==========================================
# Binance API (FREE - no key required for public endpoints)
# Optional: Add keys if using authenticated endpoints
# BINANCE_API_KEY=your_binance_key_here
# BINANCE_SECRET_KEY=your_binance_secret_here

# CoinGecko API - https://www.coingecko.com/en/api
# Free tier: 10-50 calls/min | Pro: $129/mo
# COINGECKO_API_KEY=your_coingecko_key_here

# ==========================================
# FEATURE FLAGS
# ==========================================
# Toggle live data sources vs mock data
NEXT_PUBLIC_ENABLE_LIVE_WHALE_DATA=false
NEXT_PUBLIC_ENABLE_LIVE_SENTIMENT=false
NEXT_PUBLIC_ENABLE_LIVE_TECHNICAL=false

# ==========================================
# CACHING CONFIGURATION
# ==========================================
# Redis connection string (optional - falls back to in-memory cache)
# REDIS_URL=redis://localhost:6379

# Cache TTL (in seconds)
CACHE_TTL_WHALE_DATA=300      # 5 minutes
CACHE_TTL_SENTIMENT=900        # 15 minutes
CACHE_TTL_TECHNICAL=60         # 1 minute

# ==========================================
# RATE LIMITING
# ==========================================
# Maximum API requests per service
RATE_LIMIT_WHALE_ALERT=25      # calls per minute
RATE_LIMIT_TWITTER=400          # calls per 15 minutes
RATE_LIMIT_OPENAI=500           # calls per minute

# ==========================================
# DATABASE (for signal history)
# ==========================================
# Add your database connection string
# DATABASE_URL=your_database_connection_string

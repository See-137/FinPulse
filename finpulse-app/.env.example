# FinPulse Environment Configuration Template
# ============================================
# Copy this file to .env and fill in your values
#
# IMPORTANT: Never commit real secrets to version control!
#
# To get production/staging values, run in finpulse-infrastructure/:
#   terraform output api_gateway
#   terraform output cognito
#   terraform output staging_api_url
#   terraform output staging_cognito_user_pool_id
#   terraform output staging_cognito_client_id

# =============================================================================
# API Gateway - REQUIRED
# =============================================================================
# Get from: terraform output api_gateway
VITE_API_URL=

# =============================================================================
# Cognito Authentication - REQUIRED
# =============================================================================
# Get from: terraform output cognito
VITE_COGNITO_USER_POOL_ID=
VITE_COGNITO_CLIENT_ID=
VITE_COGNITO_REGION=us-east-1

# =============================================================================
# API Keys (for client-side features)
# =============================================================================
# Get from: https://aistudio.google.com/
VITE_GEMINI_API_KEY=

# =============================================================================
# Feature Flags
# =============================================================================
VITE_ENABLE_AI=true
VITE_ENABLE_COMMUNITY=true
VITE_ENABLE_NEWS=true

# =============================================================================
# Environment Identifier
# =============================================================================
# Options: development, staging, production
VITE_ENVIRONMENT=development

# =============================================================================
# LemonSqueezy Billing - REQUIRED FOR PAID PLANS (Israeli merchants)
# =============================================================================
# LemonSqueezy is used instead of Stripe because Stripe doesn't support 
# Israeli merchants. LemonSqueezy acts as Merchant of Record, handling 
# VAT/tax compliance automatically.
#
# Sign up: https://lemonsqueezy.com
# Store ID: Dashboard > Settings > Stores > Store ID
VITE_LEMONSQUEEZY_STORE_ID=

# Get Variant IDs from: Dashboard > Products > Your Product > Variants
# Each pricing tier (ProPulse, SuperPulse) needs its own variant
VITE_LEMONSQUEEZY_VARIANT_PROPULSE=
VITE_LEMONSQUEEZY_VARIANT_SUPERPULSE=

# =============================================================================
# DEPRECATED: Stripe Billing (kept for reference)
# =============================================================================
# Stripe is NOT used - Israeli merchants not supported
# VITE_STRIPE_PUBLISHABLE_KEY=pk_test_...
# VITE_STRIPE_PRICE_PROPULSE=price_xxxxx
# VITE_STRIPE_PRICE_SUPERPULSE=price_xxxxx

# =============================================================================
# Error Monitoring (Sentry) - REQUIRED FOR PRODUCTION
# =============================================================================
# Get from: https://sentry.io > Settings > Projects > Client Keys (DSN)
VITE_SENTRY_DSN=https://xxxxx@o123456.ingest.sentry.io/123456

# =============================================================================
# Security - Token Storage Mode
# =============================================================================
# Options: localStorage (default), cookie (httpOnly - more secure)
# Use 'cookie' in production for enhanced XSS protection
VITE_TOKEN_STORAGE_MODE=localStorage

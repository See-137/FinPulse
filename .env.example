# FinPulse Environment Configuration Template
# Copy this file to .env and fill in your values

# =============================================================================
# API Gateway - Use appropriate endpoint for your environment
# =============================================================================

# For local development (pointing to production API)
VITE_API_URL=https://b3fgmin9yj.execute-api.us-east-1.amazonaws.com/prod

# For staging (when staging API Gateway is created)
# VITE_API_URL=https://STAGING_API_ID.execute-api.us-east-1.amazonaws.com/staging

# =============================================================================
# Cognito Authentication
# =============================================================================

# Production Cognito
VITE_COGNITO_USER_POOL_ID=us-east-1_b36NPuJf3
VITE_COGNITO_CLIENT_ID=4lhsbeeae63ne3vgosog38lieu

# Staging Cognito (fill in after terraform apply for staging)
# VITE_COGNITO_USER_POOL_ID=us-east-1_STAGING_POOL
# VITE_COGNITO_CLIENT_ID=STAGING_CLIENT_ID

VITE_COGNITO_REGION=us-east-1

# =============================================================================
# API Keys (for client-side features)
# =============================================================================

# Gemini AI (for streaming responses)
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# =============================================================================
# Feature Flags
# =============================================================================

VITE_ENABLE_AI=true
VITE_ENABLE_COMMUNITY=true
VITE_ENABLE_NEWS=true

# =============================================================================
# Environment Identifier
# =============================================================================

VITE_ENVIRONMENT=development

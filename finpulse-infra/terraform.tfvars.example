# FinPulse Infrastructure - Example Configuration
# Copy this to terraform.tfvars and customize

# =============================================================================
# Required Settings
# =============================================================================

environment        = "prod"
aws_region         = "us-east-1"
budget_alert_email = "your-email@example.com"  # ← CHANGE THIS!

# =============================================================================
# Budget
# =============================================================================

budget_alert_amount = 150  # Monthly budget in USD

# =============================================================================
# Feature Flags
# =============================================================================

enable_ai_service        = false  # Set true when you have Gemini API
enable_news_service      = true
enable_community_service = true
enable_nat_gateway       = true   # Required for Lambda internet access
enable_api_caching       = false  # Enable for prod (~$15/mo)

# =============================================================================
# Infrastructure Settings (Phase 1 optimized)
# =============================================================================

lambda_architecture           = "arm64"          # Graviton2 = 20% cheaper
dynamodb_billing_mode         = "PAY_PER_REQUEST"
enable_dynamodb_pitr          = false            # Enable for prod
redis_node_type               = "cache.t4g.micro"
redis_num_cache_nodes         = 1
cloudwatch_log_retention_days = 7

# =============================================================================
# CloudWatch Alarm Thresholds
# =============================================================================

lambda_error_threshold  = 5     # Alert if error rate > 5%
redis_memory_threshold  = 80    # Alert if memory > 80%
api_5xx_threshold       = 10    # Alert if > 10 5xx errors/min
api_latency_threshold   = 3000  # Alert if p95 latency > 3s

# =============================================================================
# API Keys (set via environment variables or AWS Secrets Manager)
# =============================================================================

# Don't put API keys in this file!
# Set them via AWS Secrets Manager (recommended):
#
# aws secretsmanager create-secret --name finpulse/prod/alpaca-credentials \
#   --secret-string '{"api_key":"YOUR_KEY","api_secret":"YOUR_SECRET"}'
#
# LemonSqueezy (payments) - required for paid plans:
# aws secretsmanager create-secret --name finpulse/prod/lemonsqueezy \
#   --secret-string '{"api_key":"YOUR_API_KEY","webhook_secret":"YOUR_WEBHOOK_SECRET"}'
#
# Or via environment variables for local dev:
# export ALPACA_API_KEY="your-key"
# export ALPACA_API_SECRET="your-secret"
# export TF_VAR_newsapi_key="your-key"  # Optional for news feature
# export TF_VAR_gemini_api_key=""  # Optional for AI feature
# export TF_VAR_lemonsqueezy_api_key="your-key"  # For payments
# export TF_VAR_lemonsqueezy_webhook_secret="your-secret"

# =============================================================================
# LemonSqueezy Settings (pre-configured)
# =============================================================================

# These are public IDs, safe to commit
lemonsqueezy_store_id           = "275175"
lemonsqueezy_variant_propulse   = "1229771"
lemonsqueezy_variant_superpulse = "1229849"

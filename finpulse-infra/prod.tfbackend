# Production backend config — passed to `terraform init -backend-config=prod.tfbackend`.
# Bucket name is not a secret (publicly visible in any state-related log output).
# Per-developer overrides go in *.tfbackend.local (gitignored).
bucket         = "finpulse-terraform-state-383349724213"
key            = "prod/terraform.tfstate"
region         = "us-east-1"
encrypt        = true
dynamodb_table = "terraform-state-lock"
